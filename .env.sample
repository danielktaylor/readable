# Cloudflare R2 credentials
# Copy this file to .env and fill in your values before deployment

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=your_r2_bucket_name
# Optional: custom public domain for the bucket (e.g. https://assets.example.com)
# If unset, falls back to https://<bucket>.r2.dev/<key>
R2_PUBLIC_URL=
